GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# Copperline outbound mail identity (Google Workspace SMTP)
COPPERLINE_MAIL_PROVIDER=google_workspace_smtp
COPPERLINE_FROM_EMAIL=drewyomantas@copperlineops.com
COPPERLINE_FROM_NAME=Drew @ Copperline
COPPERLINE_REPLY_TO=drewyomantas@copperlineops.com
GOOGLE_WORKSPACE_SMTP_USERNAME=drewyomantas@copperlineops.com
GOOGLE_WORKSPACE_SMTP_APP_PASSWORD=xxxx xxxx xxxx xxxx
GOOGLE_WORKSPACE_SMTP_HOST=smtp.gmail.com
GOOGLE_WORKSPACE_SMTP_PORT=465

# Keep dry-run locally. Set true only after Workspace sender + SPF/DKIM/DMARC are verified.
COPPERLINE_LIVE_SEND_ENABLED=false
SEND_DELAY_SECONDS=45
