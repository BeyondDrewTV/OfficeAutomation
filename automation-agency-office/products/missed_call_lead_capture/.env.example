# ── Twilio ─────────────────────────────────────────────────────────────────────
# console.twilio.com → Account Info
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here

# Signature validation is ON by default in production.
# Set to 1 ONLY during local dev when ngrok URL changes frequently.
# NEVER disable in production.
TWILIO_SKIP_SIGNATURE_VALIDATION=0

# ── Rate limits (per caller, per 60-second window) ─────────────────────────────
# Defaults: 3 calls/min, 10 SMS/min. Raise for high-volume clients if needed.
CALL_RATE_LIMIT_PER_MINUTE=3
SMS_RATE_LIMIT_PER_MINUTE=10

# ── SMTP (Gmail) ───────────────────────────────────────────────────────────────
# Use a Gmail App Password — NOT your real Gmail password.
# myaccount.google.com → Security → App Passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_notifications_gmail@gmail.com
SMTP_PASS=xxxx_xxxx_xxxx_xxxx

# ── Google Sheets ──────────────────────────────────────────────────────────────
GOOGLE_SERVICE_ACCOUNT_FILE=service_account.json

# ── Flask ──────────────────────────────────────────────────────────────────────
PORT=5000
FLASK_DEBUG=0
